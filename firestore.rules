rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Solo gli utenti autorizzati possono leggere e scrivere
    // TODO: Sostituire le email placeholder con quelle reali di mamma e papa'
    function isAuthorized() {
      return request.auth != null
        && request.auth.token.email in [
          "MAMMA_EMAIL@gmail.com",
          "PAPA_EMAIL@gmail.com"
        ];
    }

    match /calendars/{monthId}/slots/{slotId} {
      allow read: if isAuthorized();
      allow write: if isAuthorized()
        && request.resource.data.keys().hasAll(["assignedTo", "updatedBy", "updatedAt"])
        && request.resource.data.updatedBy == request.auth.uid;
    }
  }
}

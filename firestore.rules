rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Solo gli utenti autorizzati possono leggere e scrivere
    function isAuthorized() {
      return request.auth != null
        && request.auth.token.email in [
          "zuzanahauznerova@gmail.com",
          "sprite.lol@gmail.com"
        ];
    }

    match /calendars/{monthId}/slots/{slotId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized()
        && request.resource.data.keys().hasAll(["assignedTo", "updatedBy", "updatedAt"])
        && request.resource.data.updatedBy == request.auth.uid;
      allow delete: if isAuthorized();
    }
  }
}
